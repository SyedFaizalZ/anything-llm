    </node>
    <node id="Outdoor Billboard">
      <data key="d0">Outdoor Billboard</data>
      <data key="d1">artifact</data>
      <data key="d2">Outdoor Billboard is a form of advertising that targets a broad and undefined audience, typically anyone who drives by.</data>
      <data key="d3">chunk-8fa6a659a0983832b3e1e874781040e1</data>
      <data key="d4">Facebook Ad 60.pdf</data>
      <data key="d5">1773904703</data>
