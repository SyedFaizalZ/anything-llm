    <node id="Marketing Strategy">
      <data key="d0">Marketing Strategy</data>
      <data key="d1">concept</data>
      <data key="d2">Marketing Strategy refers to the comprehensive plan designed to achieve specific business goals through advertising and promotional efforts.</data>
      <data key="d3">chunk-8fa6a659a0983832b3e1e874781040e1</data>
      <data key="d4">Facebook Ad 60.pdf</data>
