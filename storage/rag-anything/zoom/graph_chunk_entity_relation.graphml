    <node id="Ad Campaign Scope">
      <data key="d0">Ad Campaign Scope</data>
      <data key="d1">concept</data>
      <data key="d2">Ad campaign scope defines the extent and focus of each individual advertising campaign on Facebook.</data>
      <data key="d3">chunk-d5187f72b95adf4fda2d11bfe2eae46b</data>
      <data key="d4">Facebook Ad 60.pdf</data>
      <data key="d5">1773904728</data>
