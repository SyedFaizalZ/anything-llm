    </node>
    <node id="Business Brand">
      <data key="d0">Business Brand</data>
      <data key="d1">concept</data>
      <data key="d2">Business Brand refers to the image and reputation of a business as perceived by consumers, which can be enhanced through targeted advertising.</data>
      <data key="d3">chunk-8fa6a659a0983832b3e1e874781040e1</data>
      <data key="d4">Facebook Ad 60.pdf</data>
