    </node>
    <node id="International Audience">
      <data key="d0">International Audience</data>
      <data key="d1">concept</data>
      <data key="d2">International Audience refers to a group of consumers across various countries targeted by advertising efforts.</data>
      <data key="d3">chunk-8fa6a659a0983832b3e1e874781040e1</data>
      <data key="d4">Facebook Ad 60.pdf</data>
      <data key="d5">1773904705</data>
