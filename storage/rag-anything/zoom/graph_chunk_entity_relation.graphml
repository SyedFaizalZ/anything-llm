    <node id="Target Audience">
      <data key="d0">Target Audience</data>
      <data key="d1">concept</data>
      <data key="d2">Target Audience is the specific group of consumers most likely to be interested in a product or service, defined by various demographics and behaviors.</data>
      <data key="d3">chunk-8fa6a659a0983832b3e1e874781040e1</data>
      <data key="d4">Facebook Ad 60.pdf</data>
      <data key="d5">1773904703</data>
