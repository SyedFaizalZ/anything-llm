    <node id="Target Advertising Group">
      <data key="d0">Target Advertising Group</data>
      <data key="d1">concept</data>
      <data key="d2">Target advertising group refers to the specific audience segments that can be targeted with Facebook ads.</data>
      <data key="d3">chunk-d5187f72b95adf4fda2d11bfe2eae46b</data>
