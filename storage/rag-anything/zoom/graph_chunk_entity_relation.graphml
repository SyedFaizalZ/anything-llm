    <node id="Increase Sales">
      <data key="d0">Increase Sales</data>
      <data key="d1">concept</data>
      <data key="d2">Increase Sales refers to the goal of boosting the number of products or services sold through effective marketing strategies.</data>
      <data key="d3">chunk-8fa6a659a0983832b3e1e874781040e1</data>
