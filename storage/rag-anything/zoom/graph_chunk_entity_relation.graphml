    <node id="Facebook Advertising">
      <data key="d0">Facebook Advertising</data>
      <data key="d1">method</data>
      <data key="d2">Facebook Advertising is a method of creating and running highly targeted ads on the Facebook platform.</data>
      <data key="d3">chunk-8fa6a659a0983832b3e1e874781040e1</data>
      <data key="d4">Facebook Ad 60.pdf</data>
      <data key="d5">1773904703</data>
